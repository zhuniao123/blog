---
import { SITE_AUTHOR, SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<small>&copy; {today.getFullYear()} {SITE_AUTHOR} · {SITE_TITLE} · Powered by Astro & Cloudflare Pages</small>
</footer>
<style>
	footer {
		padding: 2.5em 1em 4em 1em;
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.95rem;
	}
</style>
