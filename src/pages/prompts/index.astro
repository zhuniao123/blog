---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import PromptCard from "@/components/PromptCard.astro";
import { SITE } from "@/config";

const prompts = (await getCollection("prompts")).filter(
  prompt => prompt.data.slug !== "prompt-archive-readme"
);
const sortedPrompts = prompts.sort(
  (a, b) => b.data.sourceDate.getTime() - a.data.sourceDate.getTime()
);
const languages = [...new Set(sortedPrompts.map(prompt => prompt.data.lang))].sort();
const tags = [...new Set(sortedPrompts.flatMap(prompt => prompt.data.tags))].sort();
---

<Layout
  title={`Prompts | ${SITE.title}`}
  description="独立于博客文章的 Prompt 素材归档页，保留来源、样图和本地归档。"
>
  <Header />
  <Main
    pageTitle="Prompt Archive"
    pageDesc="这里放的是素材资产，不是评论文章。每条记录都尽量保留原始来源、可复用 prompt 和样图归档。"
  >
    <section class="mb-8 grid gap-4 rounded-3xl border border-border/80 bg-background/70 p-5 shadow-[0_18px_45px_-30px_color-mix(in_srgb,var(--accent)_30%,transparent)] sm:grid-cols-3">
      <div>
        <div class="text-3xl font-semibold text-accent">{sortedPrompts.length}</div>
        <p class="mt-2 text-sm opacity-80">当前已结构化归档的 prompt 条目</p>
      </div>
      <div>
        <div class="text-3xl font-semibold text-accent">
          {sortedPrompts.reduce((count, prompt) => count + prompt.data.archivedImages.length, 0)}
        </div>
        <p class="mt-2 text-sm opacity-80">已归档到自有地址的样图数量</p>
      </div>
      <div>
        <div class="text-3xl font-semibold text-accent">
          {sortedPrompts.reduce((count, prompt) => count + prompt.data.sampleImages.length, 0)}
        </div>
        <p class="mt-2 text-sm opacity-80">当前登记的原始样图链接数量</p>
      </div>
    </section>

    <section class="mb-8 rounded-3xl border border-border/80 bg-background/70 p-5 shadow-[0_18px_45px_-30px_color-mix(in_srgb,var(--accent)_24%,transparent)]">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <h2 class="text-xl font-semibold">筛选素材</h2>
          <p class="mt-2 text-sm opacity-80">先按语言收窄，再按标签定位，别让素材库长成无差别仓库。</p>
        </div>
        <div id="prompt-results-count" class="text-sm opacity-80">{sortedPrompts.length} 条可见</div>
      </div>

      <div class="mt-4 grid gap-4 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_auto]">
        <label class="grid gap-2 text-sm">
          <span class="font-medium">语言</span>
          <select
            id="prompt-lang-filter"
            class="rounded-2xl border border-border bg-background/80 px-4 py-3"
          >
            <option value="all">全部语言</option>
            {languages.map(lang => <option value={lang}>{lang.toUpperCase()}</option>)}
          </select>
        </label>

        <label class="grid gap-2 text-sm">
          <span class="font-medium">标签</span>
          <select
            id="prompt-tag-filter"
            class="rounded-2xl border border-border bg-background/80 px-4 py-3"
          >
            <option value="all">全部标签</option>
            {tags.map(tag => <option value={tag}>#{tag}</option>)}
          </select>
        </label>

        <button
          id="prompt-filter-reset"
          type="button"
          class="rounded-2xl border border-border px-4 py-3 text-sm font-medium transition hover:border-accent hover:text-accent"
        >
          重置筛选
        </button>
      </div>
    </section>

    <ul id="prompt-list">
      {sortedPrompts.map(prompt => <PromptCard prompt={prompt} />)}
    </ul>
  </Main>
  <Footer />
</Layout>

<script>
  function setupPromptFilters() {
    const list = document.querySelector("#prompt-list") as HTMLUListElement | null;
    const langSelect = document.querySelector("#prompt-lang-filter") as HTMLSelectElement | null;
    const tagSelect = document.querySelector("#prompt-tag-filter") as HTMLSelectElement | null;
    const resetButton = document.querySelector("#prompt-filter-reset") as HTMLButtonElement | null;
    const countNode = document.querySelector("#prompt-results-count") as HTMLDivElement | null;

    if (!list || !langSelect || !tagSelect || !resetButton || !countNode) return;

    const items = Array.from(list.querySelectorAll("[data-prompt-lang]"));
    if (items.length === 0) return;

    const applyFilters = () => {
      const selectedLang = langSelect.value;
      const selectedTag = tagSelect.value;

      let visibleCount = 0;

      items.forEach(item => {
        const itemLang = item.getAttribute("data-prompt-lang") ?? "";
        const itemTags = (item.getAttribute("data-prompt-tags") ?? "")
          .split(",")
          .filter(Boolean);

        const matchesLang = selectedLang === "all" || itemLang === selectedLang;
        const matchesTag = selectedTag === "all" || itemTags.includes(selectedTag);
        const isVisible = matchesLang && matchesTag;

        item.classList.toggle("hidden", !isVisible);
        if (isVisible) {
          visibleCount += 1;
        }
      });

      countNode.textContent = `${visibleCount} 条可见`;
    };

    langSelect.onchange = applyFilters;
    tagSelect.onchange = applyFilters;
    resetButton.onclick = () => {
      langSelect.value = "all";
      tagSelect.value = "all";
      applyFilters();
    };

    applyFilters();
  }

  setupPromptFilters();
  document.addEventListener("astro:after-swap", setupPromptFilters);
</script>